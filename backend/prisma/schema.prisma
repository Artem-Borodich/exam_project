generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

enum UserRole {
  EMPLOYEE
  MANAGER
}

model User {
  id Int @id @default(autoincrement())

  // Exam requirements: email + password + role (nullable) + isApproved
  email    String @unique
  password String?
  role     UserRole?
  isApproved Boolean @default(false)

  name String?

  // Used for optional integrations (Google OAuth for calendar events & reminders)
  googleRefreshToken   String?
  googleTokenUpdatedAt DateTime?

  createdAt DateTime @default(now())

  zonesCreated Zone[] @relation("ZoneCreatedBy")
  createdDuties Duty[] @relation("DutyCreatedBy")
  employeeDuties Duty[] @relation("DutyEmployee")
}

model Zone {
  id Int @id @default(autoincrement())

  name String
  // Exam requirements: store polygon coordinates in DB (polygon drawing support)
  polygonCoordinates Json

  createdById Int
  createdBy   User @relation("ZoneCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  duties Duty[]
}

model Duty {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   User @relation("DutyEmployee", fields: [employeeId], references: [id])

  zoneId Int
  zone   Zone @relation(fields: [zoneId], references: [id])

  // Exam requirements: date + startTime + endTime (interval)
  date DateTime
  startTime String // "HH:mm"
  endTime   String // "HH:mm"

  createdById Int
  createdBy   User @relation("DutyCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  results DutyResult[]

  @@index([zoneId, date])
}

model DutyResult {
  id Int @id @default(autoincrement())

  dutyId Int
  duty   Duty @relation(fields: [dutyId], references: [id])

  trafficLightId Int
  // Exam requirements: for each 5-minute interval store startTime + metrics
  startTime DateTime

  greenWithCars Int
  greenWithoutCars Int
  redWithCars Int
  redWithoutCars Int

  createdAt DateTime @default(now())

  // Avoid duplicates for the same duty interval and traffic light
  @@unique([dutyId, trafficLightId, startTime])
  @@index([startTime])
}

